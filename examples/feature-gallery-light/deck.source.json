        "color": "0B1220",
        "fontSize": 16,
        "bold": true
      },
      "elements": [
        {
          "id": "eyebrow",
          "type": "text",
          "text": "LIGHT THEME",
          "x": 120,
          "y": 120,
          "w": 760,
          "h": 44,
          "fontSize": 24,
          "bold": true,
          "color": "{colors.accent}"
