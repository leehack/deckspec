          ],
          "chartColors": ["{colors.accent}", "{colors.good}", "{colors.warn}"],
          "options": {
            "showLegend": false,
            "showValue": false,
            "catAxisLabelColor": "{colors.text}",
            "valAxisLabelColor": "{colors.muted}",
            "catAxisLabelFontSize": 12,
            "valAxisLabelFontSize": 12
          }
        },
        {
          "id": "footer",
          "type": "text",
          "text": "Light table/chart rendering is included in verify, not a manual screenshot.",
