        },
        {
          "id": "lightChart",
          "type": "chart",
          "x": 980,
          "y": 535,
          "w": 650,
          "h": 320,
          "chartType": "bar",
          "data": [
            {
              "name": "Evidence",
              "labels": ["Tests", "Render", "QA"],
              "values": [93, 90, 96]
