          "type": "text",
          "slot": "eyebrow",
          "style": "text.monoLabel",
          "text": "TEMPLATE PACK"
        },
        {
          "id": "title",
          "type": "text",
          "slot": "title",
          "style": "text.slideTitle",
          "text": "Templates are JSON design systems, not binary artifacts."
        },
        {
          "id": "body",
          "type": "text",
          "slot": "body",
          "style": "text.body",
          "text": "A template pack owns tokens, slots, styles, and reusable layout rules."
