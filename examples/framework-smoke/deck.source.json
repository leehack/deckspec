{
  "deckId": "framework-smoke",
  "title": "DeckSpec framework smoke deck",
  "template": "hybrid-keynote",
  "theme": "dark",
  "size": { "w": 1920, "h": 1080 },
  "slides": [
    {
      "id": "s01-framework-v0",
      "layout": "split-hero",
      "notes": "This slide explains the human-source and deterministic-build separation.",
      "elements": [
        {
          "id": "eyebrow",
          "type": "text",
          "slot": "eyebrow",
          "style": "text.monoLabel",
          "text": "FRAMEWORK V0"
        },
        {
          "id": "title",
          "type": "text",
          "slot": "title",
          "style": "text.display",
          "text": "Markdown stays human. JSON builds the deck."
        },
        {
          "id": "body",
          "type": "text",
          "slot": "body",
          "style": "text.body",
          "text": "Agents can patch deterministic low-level elements while people keep discussing narrative, content, and design in Markdown."
        },
        { "id": "hero-card", "type": "shape", "slot": "heroCard", "style": "shape.heroCard" },
        {
          "id": "hero-title",
          "type": "text",
          "slot": "heroTitle",
          "style": "text.slideTitle",
          "text": "Source → Normalize → Build"
        },
        {
          "id": "hero-body",
          "type": "text",
          "slot": "heroBody",
          "style": "text.body",
          "text": "The renderer only sees normalized JSON: explicit coordinates, resolved styles, stable element ids."
        },
        {
          "id": "footer",
          "type": "text",
          "slot": "footer",
          "style": "text.monoLabel",
          "text": "PPTX is generated output; fixes go back to JSON/template data."
        }
      ]
    },
    {
      "id": "s02-template-pack",
